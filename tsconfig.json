{
  "compilerOptions": {
    "module": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "sourceMap": true,
    "noImplicitAny": true,
    "strict": true,
    "declaration": true,           
    "emitDeclarationOnly": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "src/**/*"
  ]
}
